#!/bin/sh
mount -t proc proc /proc
mount -t sysfs sysfs /sys
mount -t devtmpfs devtmpfs /dev

CMDLINE=$(cat /proc/cmdline)
for param in $CMDLINE; do
    case "$param" in
        ip=*) export FC_IP_CONFIG="${param#*=}" ;;
        job_id=*) export IRONCLAW_JOB_ID="${param#*=}" ;;
        worker_token=*) export IRONCLAW_WORKER_TOKEN="${param#*=}" ;;
        orchestrator_url=*) export IRONCLAW_ORCHESTRATOR_URL="${param#*=}" ;;
    esac
done

if [ -n "${FC_IP_CONFIG:-}" ]; then
    IFS=':' read -r GUEST_IP _ GATEWAY_IP NETMASK _ NET_DEV _ <<EOF_IP
$FC_IP_CONFIG
EOF_IP
    NET_DEV="${NET_DEV:-eth0}"
    case "${NETMASK:-}" in
        255.255.255.252) PREFIX_LEN=30 ;;
        255.255.255.0) PREFIX_LEN=24 ;;
        255.255.0.0) PREFIX_LEN=16 ;;
        255.0.0.0) PREFIX_LEN=8 ;;
        *) PREFIX_LEN="$NETMASK" ;;
    esac
    ip link set lo up 2>/dev/null || true
    ip link set "$NET_DEV" up 2>/dev/null || true
    ip addr add "${GUEST_IP}/${PREFIX_LEN}" dev "$NET_DEV" 2>/dev/null || true
    ip route add default via "$GATEWAY_IP" dev "$NET_DEV" 2>/dev/null || true
fi

mkdir -p /workspace
if [ -e /dev/vdb ]; then
    mount /dev/vdb /workspace
fi
mkdir -p /workspace/.bench-evidence
if [ -n "${IRONCLAW_JOB_ID:-}" ]; then
    TS_MS="$(date +%s%3N)"
    HOSTNAME_VALUE="$(hostname)"
    cat > "/workspace/.bench-evidence/worker-started-${IRONCLAW_JOB_ID}.json" <<EOF_JSON
{"event":"worker_started","job_id":"${IRONCLAW_JOB_ID}","ts_unix_ms":${TS_MS},"pid":$$,"hostname":"${HOSTNAME_VALUE}"}
EOF_JSON
fi

export HOME=/workspace
export RUST_LOG="${RUST_LOG:-ironclaw=debug}"
cd /workspace
/usr/local/bin/ironclaw worker --job-id "${IRONCLAW_JOB_ID}" --orchestrator-url "${IRONCLAW_ORCHESTRATOR_URL}"
WORKER_RC=$?
sync || true
reboot -f
exit "$WORKER_RC"
