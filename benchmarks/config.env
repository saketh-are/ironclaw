# Benchmark parameters
# Override via CLI flags or environment variables

# Scale
DEFAULT_AGENTS=5
BENCHMARK_DURATION_S=300
SAMPLE_INTERVAL_MS=500

# Reproducibility
RNG_SEED=42

# Agent config
AGENT_MEMORY_MB=4096
AGENT_BASELINE_MB=50
MAX_CONCURRENT_WORKERS=5
SPAWN_INTERVAL_MEAN_S=30

# Worker config (mirrors ironclaw defaults from config/sandbox.rs)
WORKER_BACKEND=docker
WORKER_MEMORY_LIMIT_MB=2048
WORKER_MEMORY_MB=500
WORKER_DURATION_MIN_S=30
WORKER_DURATION_MAX_S=120
WORKER_LIFETIME_MODE=timed

# Plateau mode config
PLATEAU_WORKERS_PER_AGENT=
PLATEAU_HOLD_S=60
PLATEAU_SETTLE_S=20
