# Ironclaw benchmark agent — Docker-in-Docker variant.
#
# Used by gVisor-DinD and Sysbox-DinD approaches where each agent container
# has its own dockerd. The entrypoint starts dockerd, loads the sandbox worker
# image, then starts the mock LLM + ironclaw.
#
# Expects the pre-built ironclaw binary at workload/.ironclaw-bin.

FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
        python3 ca-certificates curl \
        docker.io iptables && \
    rm -rf /var/lib/apt/lists/*

# Ironclaw binary (pre-compiled on the host)
COPY .ironclaw-bin /usr/local/bin/ironclaw
RUN chmod +x /usr/local/bin/ironclaw

# Mock LLM server
COPY mock_llm_server.py /opt/mock_llm_server.py

# Docker socket proxy
COPY docker_socket_proxy.py /opt/docker_socket_proxy.py

# Entrypoint
COPY ironclaw-dind-entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

# Create workspace directory
RUN mkdir -p /tmp/workspace && chmod 777 /tmp/workspace

EXPOSE 3000

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
