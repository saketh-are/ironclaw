FROM python:3.11-slim

# Install procps for pgrep (used by approach to count active workers)
RUN apt-get update -qq && \
    apt-get install -y --no-install-recommends procps && \
    rm -rf /var/lib/apt/lists/*

COPY agent.py /usr/local/bin/agent.py

# Firecracker binary, kernel, and rootfs are bind-mounted at runtime:
#   /usr/local/bin/firecracker  (from host)
#   /opt/vmlinux                (kernel image)
#   /opt/worker-rootfs.ext4     (rootfs)
# /dev/kvm is passed via --device

ENTRYPOINT ["python3", "/usr/local/bin/agent.py"]
